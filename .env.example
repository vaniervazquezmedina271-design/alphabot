# ============================================================
#  Plantilla de variables de entorno
#  ============================================================
#  1. Copia este archivo a ".env"
#  2. Rellena solo lo que vayas a usar
#  3. NUNCA subas .env a git / internet
# ============================================================

# --- Proveedores de LLM (pon solo los que uses) ---
# El proveedor ACTIVO se elige en el dashboard (config.yaml).
# Aquí van todas las API keys que quieras tener disponibles.

OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
FIREWORKS_API_KEY=
CEREBRAS_API_KEY=
# Ollama (local): no necesita key

# --- Telegram (obligatorio para enviar reportes) ---
# 1. Habla a @BotFather en Telegram -> /newbot -> copia el token
TELEGRAM_BOT_TOKEN=
# 2. Obtén tu chat_id hablando a @userinfobot (o el del canal con -100...)
TELEGRAM_CHAT_ID=
